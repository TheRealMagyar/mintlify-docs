      {
        "group": "Collections",
        "icon": "image",
        "expanded": true,
        "pages": [
          "collections/genesis"
        ]
      },
      {
        "group": "Developer Integration",
        "icon": "cpu",
        "expanded": true,
        "pages": [
          "developer-integration/quickstart",
