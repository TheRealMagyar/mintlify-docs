{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Product Guide",
  "description": "Step-by-step guides for every product—platform setup, analytics, and integrations in one place.",
  "colors": {
    "primary": "#615D69",
    "light": "#7F83DB",
    "dark": "#7E5AA1"
  },
  "favicon": "/favicon.ico",
